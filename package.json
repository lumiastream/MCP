{
	"name": "@lumiastream/mcp",
	"version": "0.2.0",
	"description": "Model Context Protocol server for Lumia Stream",
	"type": "module",
	"bin": {
		"lumia-mcp": "dist/index.js"
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"start": "node dist/index.js",
		"typecheck": "tsc --noEmit",
		"smoke": "node smoke.mjs",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"lumiastream",
		"mcp",
		"model-context-protocol"
	],
	"license": "MIT",
	"author": "Lumia Stream",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lumiastream/mcp.git"
	},
	"homepage": "https://dev.lumiastream.com/docs/mcp/setup",
	"bugs": {
		"url": "https://github.com/lumiastream/mcp/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/node": "^26.1.0",
		"typescript": "^6.0.3"
	}
}
